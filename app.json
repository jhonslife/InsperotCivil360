{
  "expo": {
    "name": "Inspetor Civil 360",
    "slug": "inspetor-civil-360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josevital.inspetorcivil360",
      "infoPlist": {
        "NSCameraUsageDescription": "O app precisa acessar a câmera para registrar fotos das inspeções.",
        "NSPhotoLibraryUsageDescription": "O app precisa acessar a galeria para anexar fotos às inspeções.",
        "NSLocationWhenInUseUsageDescription": "O app precisa acessar a localização para registrar coordenadas das inspeções."
      }
    },
    "android": {
      "package": "com.josevital.inspetorcivil360",
      "adaptiveIcon": {
        "backgroundColor": "#1B3A5C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar a galeria para anexar fotos."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "ba42458b-c041-49ad-b9c4-ff1bb43c6953"
      }
    },
    "owner": "ooriginador"
  }
}
